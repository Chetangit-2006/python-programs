#code2:
class Library:
    def __init__(self):
        self.books = []

    def add_book(self):
        b = input("Enter book name: ")
        self.books.append(b)
        print("Book added!")

    def show_books(self):
        print("Books in library:")
        for b in self.books:
            print(b)

    def issue_book(self):
        b = input("Enter book to issue: ")
        if b in self.books:
            self.books.remove(b)
            print("Book issued!")
        else:
            print("Book not found!")

    def return_book(self):
        b = input("Enter book to return: ")
        self.books.append(b)
        print("Book returned!")


# Main Program
lib = Library()

while True:
    print("\n1.Add Book")
    print("2.Show Books")
    print("3.Issue Book")
    print("4.Return Book")
    print("5.Exit")

    ch = input("Enter choice: ")

    if ch == '1':
        lib.add_book()
    elif ch == '2':
        lib.show_books()
    elif ch == '3':
        lib.issue_book()
    elif ch == '4':
        lib.return_book()
    elif ch == '5':
        break
    else:
        print("Wrong choice!")
