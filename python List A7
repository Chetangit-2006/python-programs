# Task 13: Write a Python function that prints out the first n rows of Pascal's triangle.
def pascal_triangle(n):
    for i in range(n):
        num = 1
        for j in range(i + 1):
            print(num, end=" ")
            num = num * (i - j) // (j + 1)
        print()
//Example
