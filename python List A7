# Task 5: Write a Python function to calculate the factorial of a number.
def factorial(n):
    if n < 0:
        return "Factorial not defined for negative numbers"
    result = 1
    for i in range(1, n + 1):
        result *= i
    return result
print(factorial(5))
//Output:
//120

