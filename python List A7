# Task 14: Write a Python function to check whether a string is a pangram or not.
import string
def is_pangram(sentence):
    alphabet = set(string.ascii_lowercase)
    return set(sentence.lower()) >= alphabet
// Example
print(is_pangram("The quick brown fox jumps over the lazy dog"))
// Output:
//True

# Task 15: Write a Python program that accepts a hyphen-separated 
