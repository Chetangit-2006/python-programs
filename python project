import json
from difflib import get_close_matches

print("\n===================================================")
print("📘        ENGLISH DICTIONARY APPLICATION")
print("===================================================")
print("Hello User! Welcome to your smart dictionary.")
print("You can search meanings of many words easily.")
print("Type 'exit' anytime to close the application.")
print("===================================================\n")

# Load dictionary data
data = json.load(open("data.json"))

# Function to search word
def translate(word):

    word = word.lower()

    if word in data:
        return data[word]

    elif len(get_close_matches(word, data.keys())) > 0:

        suggestion = get_close_matches(word, data.keys())[0]

        choice = input(f"\n🤔 Did you mean '{suggestion}'? (Y/N): ")

        if choice.lower() == "y":
            return data[suggestion]

        elif choice.lower() == "n":
            return ["❌ Sorry, this word does not exist in our dictionary. Please check the spelling."]

        else:
            return ["⚠ Invalid input. Please enter Y or N."]

    else:
        return ["❌ Oops! Word not found in the dictionary. Try another word."]


while True:

    print("\n-------------------------------------------")
    category = input("🔎 Which type of word do you want?\n(technical / non-technical) or type 'exit' to quit: ")

    if category.lower() == "exit":
        print("\n===================================================")
        print("🙏 Thank you for using the English Dictionary!")
        print("We hope it helped you learn something new today.")
        print("Have a wonderful day ahead! 😊")
        print("===================================================\n")
        break

    if category.lower() not in ["technical", "non-technical"]:
        print("⚠ Please choose either 'technical' or 'non-technical'.")
        continue

    print("\n👍 Great choice! Let's find the meaning of your word.")

    word = input("✍ Enter a word: ")

    output = translate(word)

    print("\n📖 Meaning:")

    for meaning in output:
        print(" •", meaning)

    # Ask satisfaction
    satisfaction = input("\n🙂 Are you satisfied with the result? (yes/no): ")

    if satisfaction.lower() == "yes":
        print("🎉 Awesome! I'm glad I could help you.")

    else:
        print("😔 We're sorry about that.")
        print("Please try another word or check the spelling.")
        print("We'll try our best to help you next time!")
